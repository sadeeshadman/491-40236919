{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --ci --passWithNoTests",
    "check": "npm run typecheck && npm run test:ci"
  },
  "dependencies": {
    "express": "^4.21.2",
    "mongoose": "^9.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "jest": "^30.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
